# Copy to .env and edit. Environment variables override config.yaml.

HOC_HOST=0.0.0.0
HOC_PORT=8080

# Shared secret required in the X-API-Key header for all non-health endpoints.
HOC_API_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed CIDR ranges. Requests outside these ranges are rejected.
HOC_ALLOWED_CIDRS=192.168.0.0/16,10.0.0.0/8,127.0.0.1/32

# Brother QL printer model and label width.
HOC_DEFAULT_PRINTER_MODEL=QL-700
HOC_DEFAULT_LABEL_WIDTH_MM=62

# USB backend for brother_ql. "pyusb" is recommended on Raspberry Pi.
HOC_USB_BACKEND=pyusb

# Printer identifier passed to brother_ql, e.g. usb://0x04f9:0x2042 - leave blank to autodetect.
HOC_PRINTER_IDENTIFIER=

# Directories and database.
HOC_PREVIEW_DIR=/var/lib/hoc-label-print/previews
HOC_LOG_DIR=/var/log/hoc-label-print
HOC_DB_PATH=/var/lib/hoc-label-print/jobs.db
HOC_FONT_DIR=/opt/hoc-label-print/fonts

HOC_DEBUG=false
HOC_QUEUE_CONCURRENCY=1

# Idempotency window in seconds for duplicate job_ref submissions (0 disables).
HOC_IDEMPOTENCY_WINDOW_SECONDS=120

# Rate limiting (requests per minute per client IP).
HOC_RATE_LIMIT_PER_MINUTE=60
